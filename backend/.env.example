PORT=3000
NODE_ENV=production

# Usar endpoint UNPOOLED de Neon (soporta options/search_path)
# En Neon dashboard: Connection Details → toggle "Pooled" OFF → copiar URL
DATABASE_URL=postgresql://user:pass@ep-xxx-unpooled.us-east-2.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=cadena_aleatoria_min_32_chars
JWT_EXPIRES_IN=8h

# CORS: URL del frontend en Vercel (sin trailing slash)
CORS_ORIGIN=https://tu-app.vercel.app

# Email para recuperación de contraseña
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=correo@dominio.com
MAIL_PASS=app_password_gmail

UPLOAD_PATH=src/uploads
MAX_FILE_SIZE_MB=100
